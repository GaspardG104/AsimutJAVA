<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="guid.net.asimutjava.controllers.CreateStageController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Formulaire Stage" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtLibelle" promptText="Libellé du stage" />
    <TextField fx:id="txtEntreprise" promptText="Nom de l'entreprise" />
    <TextArea fx:id="txtDescription" promptText="Description" prefHeight="80"/>
    <DatePicker fx:id="dpDateDebut" promptText="Date début" maxWidth="Infinity"/>
    <DatePicker fx:id="dpDateFin" promptText="Date fin" maxWidth="Infinity"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" />
        <Button text="Enregistrer" onAction="#saveStage" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
    </HBox>
</VBox>