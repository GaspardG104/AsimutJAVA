<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="guid.net.asimutjava.controllers.ProjetController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Liste des Projets Asimov" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Nouveau Projet" onAction="#openCreateWindow"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
        <Button text="Editer Projet" fx:id="btnModifier" onAction="#openEditWindow"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
        <Button text="Supprimer sélection" onAction="#deleteProjet"
                style="-fx-background-color: #ff4444; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="tableProjets" prefHeight="400.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colLibelle" prefWidth="150.0" text="Nom du projet" />
            <TableColumn fx:id="colDescription" prefWidth="250.0" text="Description" />
            <TableColumn fx:id="colResponsable" prefWidth="150.0" text="Responsable" />
            <TableColumn fx:id="colDatedebut" prefWidth="150.0" text="Date du début" />
            <TableColumn fx:id="colDatefin" prefWidth="150.0" text="Date de fin" />
        </columns>
    </TableView>
</VBox>